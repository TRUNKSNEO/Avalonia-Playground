<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:MyAvalonia.ViewModels"
			 xmlns:wf="clr-namespace:MyAvalonia.Views.WeatherForecast"
			 mc:Ignorable="d"
			 d:DesignWidth="800"
			 d:DesignHeight="450"
			 x:Class="MyAvalonia.Views.WeatherForecastPageView"
			 x:DataType="vm:WeatherForecastPageViewModel"
			 xmlns:local="clr-namespace:MyAvalonia.Models.Forecast"
			 xmlns:awarness="clr-namespace:MyAvalonia.Models.Awarness">

	<Grid RowDefinitions="Auto,*">
		<Border Grid.Row="0" Padding="20">
			<StackPanel Spacing="10">

				<StackPanel Orientation="Horizontal">
					<TextBlock Text="Weather Forecast!" FontSize="18" />
				</StackPanel>

				<StackPanel Orientation="Horizontal">
					<TextBlock Text="Select location" FontSize="18" Margin="0,5,5,0" />

					<ComboBox Width="200"
							  ItemsSource="{Binding Locations}"
							  SelectedItem="{Binding SelectedLocation}">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<StackPanel>
									<TextBlock Text="{Binding Name}" FontWeight="Bold"/>
								</StackPanel>
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
				</StackPanel>
			</StackPanel>
		</Border>
		<Border Grid.Row="1">
			<wf:WeatherForecastList />
		</Border>
	</Grid>
</UserControl>

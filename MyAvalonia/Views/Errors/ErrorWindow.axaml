<Window xmlns="https://github.com/avaloniaui"
		xmlns:vm="using:MyAvalonia.ViewModels"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d"
		x:Class="MyAvalonia.ErrorWindow"
		x:DataType="vm:ErrorWindowViewModel"
		Width="650"
		Height="450"
		Title="Erro"
		Background="#1E1E1E"
		SystemDecorations="None"
		CanResize="False">

	<Border CornerRadius="10"
			Background="#2A2A2A"
			BorderBrush="#444"
			BorderThickness="1">

		<Grid RowDefinitions="Auto,*,Auto">

			<!-- HEADER -->
			<Border Background="#C62828" Padding="12">
				<Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">

					<Label Foreground="Black" FontSize="16" FontFamily="{DynamicResource ResourceKey=PhosphorFill}" Classes="icon" Content="&#xE4E0;"> </Label>


					<TextBlock Foreground="Black" Text="Erro na aplicação"
							   Grid.Column="1"
							   FontSize="16"
							   FontWeight="Bold"
							   VerticalAlignment="Center"/>

				</Grid>
			</Border>

			<!-- CONTENT -->
			<ScrollViewer Grid.Row="1" Margin="12">
				<TextBox Text="{Binding ErrorMessage}"
						 IsReadOnly="True"
						 AcceptsReturn="True"
						 TextWrapping="Wrap"
						 Background="#1E1E1E"
						 Foreground="White"
						 BorderThickness="0"
						 FontFamily="Consolas"
						 Padding="10"/>
			</ScrollViewer>

			<!-- FOOTER -->
			<StackPanel Grid.Row="2"
						Orientation="Horizontal"
						HorizontalAlignment="Right"
						Margin="12">

				<Button Content="Fechar"
						Width="100"
						Background="#C62828"
						Foreground="Black"
						FontWeight="Bold"
						HorizontalContentAlignment="Center"
						VerticalContentAlignment="Center"
						Click="Close_Click"/>
			</StackPanel>

		</Grid>
	</Border>
</Window>